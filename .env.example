# Server Configuration
IP=127.0.0.1
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=mongodb://localhost:27017/alygo

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE_IN=30d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PAYMENT_SUCCESS=your_stripe_payment_success_url
BASE_URL=http://localhost:5000
CURRENCY=usd

# Email Configuration
EMAIL_FROM=noreply@alygo.com
EMAIL_USER=your_email_user
EMAIL_PORT=587
EMAIL_HOST=smtp.gmail.com
EMAIL_PASS=your_email_password

# Admin Configuration
ADMIN_EMAIL=admin@alygo.com
ADMIN_PASSWORD=admin123

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SERVICE_SID=your_twilio_service_sid

# Firebase Configuration
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_PROJECT_ID=your_firebase_project_id

# AFRIKSMS Configuration
AFRIKSMS_CLIENT_ID=your_afriksms_client_id
AFRIKSMS_API_KEY=your_afriksms_api_key
AFRIKSMS_SENDER_ID=AFRIKSMS
AFRIKSMS_CALLBACK_URL=your_afriksms_callback_url

# Driver Matching Configuration
# Initial search radius in kilometers (default: 5km)
INITIAL_SEARCH_RADIUS_KM=5
# Distance to expand radius in kilometers (default: 3km)
RADIUS_EXPANSION_DISTANCE_KM=3
# How long a driver can see a request in seconds (default: 60 seconds)
DRIVER_VISIBILITY_DURATION_SECONDS=60
# Overall ride request lifetime in seconds (default: 300 seconds = 5 minutes)
RIDE_REQUEST_LIFETIME_SECONDS=300
# Maximum search radius in kilometers (default: 50km)
MAX_SEARCH_RADIUS_KM=50

# Live Tracking Configuration
# Minimum interval between location updates in seconds (default: 2 seconds)
MIN_LOCATION_UPDATE_INTERVAL_SECONDS=2
# Minimum movement distance in meters to trigger update (default: 10 meters)
MIN_MOVEMENT_DISTANCE_METERS=10
# Maximum GPS accuracy tolerance in meters (default: 50 meters)
MAX_GPS_ACCURACY_TOLERANCE_METERS=50
# Driver arrival detection radius in meters (default: 30 meters)
ARRIVAL_RADIUS_METERS=30
# ETA refresh interval in seconds (default: 10 seconds)
ETA_REFRESH_INTERVAL_SECONDS=10
# Average speed for ETA calculation in km/h (default: 40 km/h)
AVERAGE_SPEED_KMH=40
# Enable socket optimization to reduce duplicate events (default: true)
ENABLE_SOCKET_OPTIMIZATION=true

# Recent Destinations Configuration
# Maximum number of recent destinations to keep per passenger (default: 20)
MAX_RECENT_DESTINATIONS=20

# Cron Job Configuration
START_CRON=true

# Client URL
CLIENT_URL=http://localhost:3000

# Support Email
SUPPORT_RECEIVER_EMAIL=support@alygo.com
